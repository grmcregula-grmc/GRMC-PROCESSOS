# NEXT_PUBLIC_APPWRITE_ENDPOINT: The endpoint URL of your Appwrite project.
NEXT_PUBLIC_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"

# NEXT_PUBLIC_APPWRITE_PROJECT_ID: The Project ID of your Appwrite project.
NEXT_PUBLIC_APPWRITE_PROJECT_ID="69cef11a002eb6dbc1c5"

# NEXT_PUBLIC_APPWRITE_DATABASE_ID: The Database ID of your Appwrite project.
NEXT_PUBLIC_APPWRITE_DATABASE_ID=""

# NEXT_PUBLIC_APPWRITE_PROCESSES_COLLECTION_ID: The Collection ID for processes.
NEXT_PUBLIC_APPWRITE_PROCESSES_COLLECTION_ID=""

# NEXT_PUBLIC_APPWRITE_NORMATIVOS_COLLECTION_ID: The Collection ID for normativos.
NEXT_PUBLIC_APPWRITE_NORMATIVOS_COLLECTION_ID=""

# NEXT_PUBLIC_APPWRITE_BUCKET_ID: The Bucket ID for storage.
NEXT_PUBLIC_APPWRITE_BUCKET_ID=""

# NEXT_PUBLIC_BACK4APP_APP_ID: The Application ID of your Back4App project. (Deprecated)
NEXT_PUBLIC_BACK4APP_APP_ID="MY_BACK4APP_APP_ID"

# NEXT_PUBLIC_BACK4APP_JS_KEY: The JavaScript Key of your Back4App project. (Deprecated)
NEXT_PUBLIC_BACK4APP_JS_KEY="MY_BACK4APP_JS_KEY"

# NEXT_PUBLIC_SUPABASE_URL: The URL of your Supabase project. (Deprecated)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: The anonymous key of your Supabase project. (Deprecated)
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_PKtj89aIhTEKKZ1dOkmRoQ_97flFjVD"

# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
